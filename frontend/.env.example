# ─────────────────────────────────────────────────────────────
# WallMind Frontend — Environment Variables Template
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values for local dev.
# In Vercel → Project Settings → Environment Variables,
# add VITE_API_URL with your deployed backend URL.
# ─────────────────────────────────────────────────────────────

# Base URL of your deployed backend (NO trailing slash)
# Local dev example:  http://localhost:5000
# Production example: https://wallmind.onrender.com
VITE_API_URL=https://your-backend-url.onrender.com
